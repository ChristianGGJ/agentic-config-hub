{
  "name": "Customer Portal MVP",
  "objective": "Launch a self-service customer portal covering login, account dashboard, and billing history by end of quarter.",
  "wbs": [
    {
      "id": "1",
      "description": "Discovery and requirements",
      "children": [
        {
          "id": "1.1",
          "description": "Stakeholder requirements workshop",
          "deliverable": "Signed requirements register",
          "owner": "business-analyst",
          "estimate_hours": 16,
          "estimate_basis": "analogous: two prior discovery workshops"
        },
        {
          "id": "1.2",
          "description": "Scope statement with explicit exclusions",
          "deliverable": "Approved scope statement",
          "owner": "project-manager",
          "estimate_hours": 12,
          "estimate_basis": "expert judgment"
        }
      ]
    },
    {
      "id": "2",
      "description": "Portal build",
      "children": [
        {
          "id": "2.1",
          "description": "Authentication module",
          "children": [
            {
              "id": "2.1.1",
              "description": "Login and session management",
              "deliverable": "Login flow passing the auth test suite",
              "owner": "backend-dev",
              "estimate_hours": 40,
              "estimate_basis": "analogous: Q1 auth revamp actuals"
            },
            {
              "id": "2.1.2",
              "description": "Password reset flow",
              "deliverable": "Reset flow with rate limiting enabled",
              "owner": "backend-dev",
              "estimate_hours": 24,
              "estimate_basis": "expert judgment"
            }
          ]
        },
        {
          "id": "2.2",
          "description": "Account dashboard",
          "children": [
            {
              "id": "2.2.1",
              "description": "Usage summary widgets",
              "deliverable": "Dashboard widgets rendering live usage data",
              "owner": "frontend-dev",
              "estimate_hours": 32,
              "estimate_basis": "three-point estimate"
            },
            {
              "id": "2.2.2",
              "description": "Billing history view",
              "deliverable": "Paginated billing history with CSV export",
              "owner": "frontend-dev",
              "estimate_hours": 24,
              "estimate_basis": "three-point estimate"
            }
          ]
        }
      ]
    },
    {
      "id": "3",
      "description": "Verification and launch",
      "children": [
        {
          "id": "3.1",
          "description": "System test cycle",
          "deliverable": "Test report with zero open critical defects",
          "owner": "qa-engineer",
          "estimate_hours": 40,
          "estimate_basis": "analogous: previous release test cycle"
        },
        {
          "id": "3.2",
          "description": "Production deployment and go-live",
          "deliverable": "Portal live behind production DNS with rollback runbook",
          "owner": "devops-engineer",
          "estimate_hours": 16,
          "estimate_basis": "expert judgment",
          "milestone": true
        },
        {
          "id": "3.3",
          "description": "User training pack",
          "deliverable": "Training deck and quick-start guide published",
          "owner": "business-analyst",
          "estimate_hours": 24,
          "estimate_basis": "expert judgment"
        }
      ]
    }
  ]
}
